{
  "expo": {
    "name": "Enterprise Expo RN Boilerplate",
    "slug": "sme-panindo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "exporntsb",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.enterprise.expo-rn-boilerplate"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.enterprise.expo_rn_boilerplate",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-sqlite"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a7d8ce2b-1397-49c5-9e6b-2889b24f4bf6"
      }
    },
    "owner": "kiskue"
  }
}
