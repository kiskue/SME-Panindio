{
  "name": "enterprise-expo-rn-boilerplate",
  "description": "Enterprise-grade Expo React Native TypeScript boilerplate with authentication, onboarding, protected routes, notifications, and modern development practices.",
  "license": "MIT",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "storybook": "storybook start -p 7007",
    "storybook:web": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "eas-build": "eas build --platform all",
    "eas-submit": "eas submit --platform all"
  },
  "dependencies": {
    "expo": "~54.0.27",
    "expo-status-bar": "~3.0.9",
    "expo-router": "~4.0.17",
    "expo-linking": "~7.0.5",
    "expo-constants": "~17.0.7",
    "expo-secure-store": "~14.0.1",
    "expo-notifications": "~0.29.13",
    "expo-device": "~7.0.2",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "zustand": "^5.0.2",
    "@react-native-async-storage/async-storage": "2.1.0",
    "@tanstack/react-query": "^5.62.7",
    "axios": "^1.7.9",
    "react-hook-form": "^7.54.0",
    "@hookform/resolvers": "^3.9.1",
    "yup": "^1.4.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-native": "^5.0.0",
    "prettier": "^3.4.2",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.3",
    "@testing-library/react-native": "^12.9.0",
    "@testing-library/jest-native": "^5.4.3",
    "@storybook/react-native": "^7.6.20",
    "@storybook/addon-ondevice-controls": "^7.6.20",
    "@storybook/addon-ondevice-actions": "^7.6.20",
    "@storybook/addon-ondevice-backgrounds": "^7.6.20"
  }
}