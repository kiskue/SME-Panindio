{
  "name": "enterprise-expo-rn-boilerplate",
  "version": "1.0.0",
  "description": "Enterprise-grade Expo React Native TypeScript boilerplate with authentication, onboarding, protected routes, notifications, and modern development practices.",
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "storybook": "EXPO_PUBLIC_STORYBOOK=1 expo start",
    "storybook:android": "EXPO_PUBLIC_STORYBOOK=1 expo start --android",
    "storybook:ios": "EXPO_PUBLIC_STORYBOOK=1 expo start --ios",
    "eas-build": "eas build --platform all",
    "eas-submit": "eas submit --platform all",
    "postinstall": "node scripts/patch-storybook.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "5.0.1",
    "@tanstack/react-query": "^5.62.7",
    "axios": "^1.7.9",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.21",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^0.575.0",
    "react": "19.1.0",
    "react-hook-form": "^7.54.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "yup": "^1.4.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@storybook/addon-ondevice-actions": "^7.6.20",
    "@storybook/addon-ondevice-backgrounds": "^7.6.20",
    "@storybook/addon-ondevice-controls": "^7.6.20",
    "@storybook/react-native": "^7.6.20",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.16",
    "prettier": "^3.4.2",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.2.4"
  }
}
